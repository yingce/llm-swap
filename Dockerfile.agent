ARG BASE_IMAGE=nvidia/cuda:12.8.1-cudnn-runtime-ubuntu22.04

FROM golang:1.23-bookworm AS agent-build

ARG HTTP_PROXY=
ARG HTTPS_PROXY=
ARG NO_PROXY=
ARG ALL_PROXY=
ARG http_proxy=
ARG https_proxy=
ARG no_proxy=
ARG all_proxy=

ENV HTTP_PROXY=${HTTP_PROXY}
ENV HTTPS_PROXY=${HTTPS_PROXY}
ENV NO_PROXY=${NO_PROXY}
ENV ALL_PROXY=${ALL_PROXY}
ENV http_proxy=${http_proxy}
ENV https_proxy=${https_proxy}
ENV no_proxy=${no_proxy}
ENV all_proxy=${all_proxy}
ENV HOME=/root
ENV GOTOOLCHAIN=auto

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY cmd ./cmd
COPY internal ./internal
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/llm-swap-agent ./cmd/agent

FROM ${BASE_IMAGE}

SHELL ["/bin/bash", "-lc"]

ARG HTTP_PROXY=
ARG HTTPS_PROXY=
ARG NO_PROXY=
ARG ALL_PROXY=
ARG http_proxy=
ARG https_proxy=
ARG no_proxy=
ARG all_proxy=
ARG DEBIAN_FRONTEND=noninteractive
ARG LLMSWAP_ROOT=/opt/llmswap
ARG LLMSWAP_CUDA_VERSION=12.8
ARG LLMSWAP_RUNTIME=all
ARG LLMSWAP_PYTHON=3.12
ARG LLMSWAP_INSTALL_TAILSCALE=1
ARG LLMSWAP_LLAMA_CPP_BASE_URL=http://llmfs-bj.oss-cn-beijing.aliyuncs.com/models
ARG LLMSWAP_LLAMA_CPP_CUDA=auto
ARG LLMSWAP_LLAMA_CPP_ARCH=sm89
ARG LLMSWAP_VLLM_PACKAGE=vllm[audio]
ARG LLMSWAP_SGLANG_PACKAGE=sglang
ARG LLMSWAP_SWAP_PORT=6006
ARG LLAMA_SWAP_DOWNLOAD_URL=
ARG LLAMA_SWAP_REF=v232
ARG LLAMA_SWAP_RELEASE_URL=
ARG UV_INDEX_URL=
ARG UV_EXTRA_INDEX_URL=
ARG PIP_INDEX_URL=
ARG PIP_EXTRA_INDEX_URL=
ARG LLMSWAP_UV_PYTHON_INSTALL_MIRROR=
ARG LLMSWAP_TORCH_INDEX_URL=
ARG LLMSWAP_TORCH_INDEX_URL_BASE=

ENV LLMSWAP_ROOT=${LLMSWAP_ROOT}
ENV HTTP_PROXY=${HTTP_PROXY}
ENV HTTPS_PROXY=${HTTPS_PROXY}
ENV NO_PROXY=${NO_PROXY}
ENV ALL_PROXY=${ALL_PROXY}
ENV http_proxy=${http_proxy}
ENV https_proxy=${https_proxy}
ENV no_proxy=${no_proxy}
ENV all_proxy=${all_proxy}
ENV HOME=/root
ENV LLMSWAP_LLAMA_CPP_ARCH=${LLMSWAP_LLAMA_CPP_ARCH}
ENV LLMSWAP_VLLM_PACKAGE=${LLMSWAP_VLLM_PACKAGE}
ENV LLMSWAP_SGLANG_PACKAGE=${LLMSWAP_SGLANG_PACKAGE}
ENV LLMSWAP_UV_PYTHON_INSTALL_MIRROR=${LLMSWAP_UV_PYTHON_INSTALL_MIRROR}
ENV LLMSWAP_TORCH_INDEX_URL=${LLMSWAP_TORCH_INDEX_URL}
ENV LLMSWAP_TORCH_INDEX_URL_BASE=${LLMSWAP_TORCH_INDEX_URL_BASE}
ENV LLAMA_SWAP_REF=${LLAMA_SWAP_REF}
ENV LLAMA_SWAP_RELEASE_URL=${LLAMA_SWAP_RELEASE_URL}
ENV LLMSWAP_UV_CACHE_DIR=${LLMSWAP_ROOT}/cache/uv
ENV LLMSWAP_UV_PYTHON_INSTALL_DIR=${LLMSWAP_ROOT}/python
ENV UV_CACHE_DIR=${LLMSWAP_ROOT}/cache/uv
ENV UV_PYTHON_INSTALL_DIR=${LLMSWAP_ROOT}/python
ENV UV_INDEX_URL=${UV_INDEX_URL}
ENV UV_EXTRA_INDEX_URL=${UV_EXTRA_INDEX_URL}
ENV PIP_INDEX_URL=${PIP_INDEX_URL}
ENV PIP_EXTRA_INDEX_URL=${PIP_EXTRA_INDEX_URL}
ENV UV_LINK_MODE=copy
ENV PATH=${LLMSWAP_ROOT}/bin:/root/.local/bin:${PATH}

WORKDIR /src

COPY scripts/install-worker.sh /usr/local/bin/install-worker.sh
COPY scripts/agent-container-entrypoint.sh /usr/local/bin/agent-container-entrypoint.sh
COPY --from=agent-build /out/llm-swap-agent /tmp/llm-swap-agent

RUN chmod 0755 /usr/local/bin/install-worker.sh /usr/local/bin/agent-container-entrypoint.sh \
 && /usr/local/bin/install-worker.sh \
      --root "${LLMSWAP_ROOT}" \
      --cuda-version "${LLMSWAP_CUDA_VERSION}" \
      --runtime "${LLMSWAP_RUNTIME}" \
      --python "${LLMSWAP_PYTHON}" \
      --llamacpp-base-url "${LLMSWAP_LLAMA_CPP_BASE_URL}" \
      --llamacpp-cuda "${LLMSWAP_LLAMA_CPP_CUDA}" \
      --agent-binary /tmp/llm-swap-agent \
      --agent-id "container-worker" \
      --tags "gpu" \
      --gateway-url "http://gateway.example.local:8080" \
      --agent-token "agent-token" \
      --llama-swap-token "agent-token" \
      --swap-port "${LLMSWAP_SWAP_PORT}" \
      --skip-tailscale \
 && rm -f "${LLMSWAP_ROOT}/agent.yaml" \
 && release_url="${LLAMA_SWAP_RELEASE_URL:-https://github.com/mostlygeek/llama-swap/releases/download/${LLAMA_SWAP_REF}/llama-swap_${LLAMA_SWAP_REF#v}_linux_amd64.tar.gz}" \
 && curl -fL --retry 5 --retry-delay 5 -o /tmp/llama-swap-release.tar.gz "$release_url" \
 && mkdir -p /tmp/llama-swap-release \
 && tar -C /tmp/llama-swap-release -xzf /tmp/llama-swap-release.tar.gz \
 && install -m 0755 /tmp/llama-swap-release/llama-swap "${LLMSWAP_ROOT}/bin/llama-swap.bundled" \
 && install -m 0755 /tmp/llama-swap-release/llama-swap "${LLMSWAP_ROOT}/bin/llama-swap" \
 && if [[ "${LLMSWAP_INSTALL_TAILSCALE}" == "1" ]]; then \
      /usr/local/bin/install-worker.sh \
        --root "${LLMSWAP_ROOT}" \
        --only tailscale \
        --cuda-version "${LLMSWAP_CUDA_VERSION}" ; \
    fi \
 && if [[ -n "${LLAMA_SWAP_DOWNLOAD_URL}" ]]; then \
      curl -fL --retry 5 --retry-delay 5 -o "${LLMSWAP_ROOT}/bin/llama-swap.bundled" "${LLAMA_SWAP_DOWNLOAD_URL}" \
      && chmod 0755 "${LLMSWAP_ROOT}/bin/llama-swap.bundled" \
      && install -m 0755 "${LLMSWAP_ROOT}/bin/llama-swap.bundled" "${LLMSWAP_ROOT}/bin/llama-swap" ; \
    elif [[ -x "${LLMSWAP_ROOT}/bin/llama-swap" ]]; then \
      install -m 0755 "${LLMSWAP_ROOT}/bin/llama-swap" "${LLMSWAP_ROOT}/bin/llama-swap.bundled" ; \
    else \
      printf 'WARN no preinstalled %s/bin/llama-swap was found after downloading llama-swap ref %s; provide LLAMA_SWAP_DOWNLOAD_URL or inspect the release URL.\n' "${LLMSWAP_ROOT}" "${LLAMA_SWAP_REF}" ; \
    fi \
 && rm -rf /tmp/llm-swap-agent /tmp/llama-swap-release /tmp/llama-swap-release.tar.gz

WORKDIR ${LLMSWAP_ROOT}

VOLUME ["/opt/llmswap/models", "/opt/llmswap/logs"]

ENTRYPOINT ["/usr/local/bin/agent-container-entrypoint.sh"]
CMD []

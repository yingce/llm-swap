FROM node:22-bookworm AS ui-build

WORKDIR /src/ui/admin

COPY ui/admin/package.json ui/admin/package-lock.json ./
RUN npm ci

COPY ui/admin ./
RUN npm run build

FROM golang:1.23-bookworm AS build

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
COPY --from=ui-build /src/internal/gateway/admin_dist ./internal/gateway/admin_dist
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/llm-swap-gateway ./cmd/gateway

FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/llmswap

COPY --from=build /out/llm-swap-gateway /usr/local/bin/llm-swap-gateway

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/llm-swap-gateway"]
CMD ["--config", "/opt/llmswap/gateway.yaml"]

FROM node:22-bookworm AS ui-build

WORKDIR /src/ui/admin

COPY ui/admin/package.json ui/admin/package-lock.json ./
RUN npm ci

COPY ui/admin ./
RUN npm run build

FROM golang:1.23-bookworm AS build

ARG HTTP_PROXY=
ARG HTTPS_PROXY=
ARG NO_PROXY=
ARG ALL_PROXY=
ARG http_proxy=
ARG https_proxy=
ARG no_proxy=
ARG all_proxy=
ARG LLMSWAP_BUILD_VERSION=
ARG LLMSWAP_BUILD_COMMIT=
ARG LLMSWAP_BUILD_TIME=

WORKDIR /src

COPY go.mod go.sum ./
RUN export HTTP_PROXY="${HTTP_PROXY}" HTTPS_PROXY="${HTTPS_PROXY}" NO_PROXY="${NO_PROXY}" ALL_PROXY="${ALL_PROXY}" \
          http_proxy="${http_proxy}" https_proxy="${https_proxy}" no_proxy="${no_proxy}" all_proxy="${all_proxy}" \
 && go mod download

COPY . .
COPY --from=ui-build /src/internal/gateway/admin_dist ./internal/gateway/admin_dist
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
      -ldflags "-X llm-swap/internal/buildinfo.Version=${LLMSWAP_BUILD_VERSION} -X llm-swap/internal/buildinfo.Commit=${LLMSWAP_BUILD_COMMIT} -X llm-swap/internal/buildinfo.BuildTime=${LLMSWAP_BUILD_TIME}" \
      -o /out/llm-swap-gateway ./cmd/gateway

FROM debian:bookworm-slim

SHELL ["/bin/bash", "-lc"]

ARG HTTP_PROXY=
ARG HTTPS_PROXY=
ARG NO_PROXY=
ARG ALL_PROXY=
ARG http_proxy=
ARG https_proxy=
ARG no_proxy=
ARG all_proxy=
ARG DEBIAN_FRONTEND=noninteractive
ARG LLMSWAP_INSTALL_TAILSCALE=1

ENV HOME=/root

RUN export HTTP_PROXY="${HTTP_PROXY}" HTTPS_PROXY="${HTTPS_PROXY}" NO_PROXY="${NO_PROXY}" ALL_PROXY="${ALL_PROXY}" \
          http_proxy="${http_proxy}" https_proxy="${https_proxy}" no_proxy="${no_proxy}" all_proxy="${all_proxy}" \
 && apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl supervisor \
    && rm -rf /var/lib/apt/lists/*

RUN export HTTP_PROXY="${HTTP_PROXY}" HTTPS_PROXY="${HTTPS_PROXY}" NO_PROXY="${NO_PROXY}" ALL_PROXY="${ALL_PROXY}" \
          http_proxy="${http_proxy}" https_proxy="${https_proxy}" no_proxy="${no_proxy}" all_proxy="${all_proxy}" \
 && if [[ "${LLMSWAP_INSTALL_TAILSCALE}" == "1" ]]; then \
      curl -fsSL https://tailscale.com/install.sh | sh; \
    fi

WORKDIR /opt/llmswap

COPY --from=build /out/llm-swap-gateway /usr/local/bin/llm-swap-gateway
COPY scripts/gateway-container-entrypoint.sh /usr/local/bin/gateway-container-entrypoint.sh

RUN sed -i 's/\r$//' /usr/local/bin/gateway-container-entrypoint.sh \
 && chmod 0755 /usr/local/bin/gateway-container-entrypoint.sh \
 && mkdir -p /opt/llmswap/bin /opt/llmswap/logs /opt/llmswap/tailscale /etc/supervisor/conf.d

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/gateway-container-entrypoint.sh"]
CMD []
